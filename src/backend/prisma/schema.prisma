// Privacy-First Storytelling Platform
// Auth tables are for session gating only — NEVER linked to posts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Session Tables (gate only, not linked to content) ───

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  role          String    @default("user") // "user" | "admin"
  sessions      Session[]
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("users")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Content Tables (completely anonymous) ───

model Group {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  isPrivate Boolean  @default(false)
  passcode  String?
  posts     Post[]
  createdAt DateTime @default(now())

  @@map("groups")
}

// Composite type for denormalized reaction counts
type ReactionCounts {
  like  Int @default(0)
  love  Int @default(0)
  haha  Int @default(0)
  wow   Int @default(0)
  sad   Int @default(0)
  angry Int @default(0)
}

model Post {
  id                  String            @id @default(auto()) @map("_id") @db.ObjectId
  content             String
  imageUrl            String?           @map("image_url")
  flowerPseudonym     String            @map("flower_pseudonym")
  
  category            String            @default("story")
  tags                String[]          @default([])
  publicationStatus   String            @default("published")
  riskScore           Int               @default(0) @map("risk_score")
  moderationReason    String?           @map("moderation_reason")
  
  // Denormalized counts for faster queries
  reactionCounts      ReactionCounts?
  
  group               Group             @relation(fields: [groupId], references: [id])
  groupId             String            @map("group_id") @db.ObjectId
  
  reactions           Reaction[]
  comments            Comment[]
  reports             Report[]
  moderationActions   ModerationAction[]
  moderationQueue     ModerationQueue?
  
  isFlagged           Boolean           @default(false) @map("is_flagged")
  isRemoved           Boolean           @default(false) @map("is_removed")
  createdAt           DateTime          @default(now()) @map("created_at")

  @@map("posts")
}

model Reaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reactions")
}

model Comment {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  content         String
  flowerPseudonym String   @map("flower_pseudonym")
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId          String   @map("post_id") @db.ObjectId
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("comments")
}

// ─── Moderation Tables ───

model Report {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id") @db.ObjectId
  reason    String   // "harassment", "spam", "inappropriate", "other"
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reports")
}

model ModerationAction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id") @db.ObjectId
  action    String   // "flagged", "removed", "dismissed"
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("moderation_actions")
}

model ModerationQueue {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId          String   @unique @map("post_id") @db.ObjectId
  content         String
  category        String
  tags            String[] @default([])
  riskScore       Int      @map("risk_score")
  moderationReason String?  @map("moderation_reason")
  status          String   @default("pending")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?  @map("reviewed_by") @db.ObjectId
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("moderation_queue")
}
