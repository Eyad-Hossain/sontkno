{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/actions/*": ["./src/backend/actions/*"],
      "@/prisma/*": ["./src/backend/prisma/*"],
      "@/lib/*": ["./src/backend/lib/*"],
      "@/components/*": ["./src/frontend/components/*"],
      "@/api/*": ["./src/api/*"],
      "@/*": ["./src/*", "./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "src/backend/**/*.ts",
    "src/api/**/*.ts",
    "src/frontend/**/*.ts",
    "src/frontend/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
