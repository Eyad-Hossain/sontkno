// Privacy-First Storytelling Platform
// Auth tables are for session gating only — NEVER linked to posts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Session Tables (gate only, not linked to content) ───

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  role          String    @default("user") // "user" | "admin"
  sessions      Session[]
  createdAt     DateTime  @default(now()) @map("created_at")

  // This User model exists ONLY for NextAuth session management.
  // It has NO relation to Post, Comment, or Reaction.

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Content Tables (completely anonymous) ───

model Group {
  id        String   @id @default(cuid())
  name      String
  isPrivate Boolean  @default(false)
  passcode  String?
  posts     Post[]
  createdAt DateTime @default(now())

  @@map("groups")
}

model Post {
  id                  String            @id @default(cuid())
  content             String
  imageUrl            String?           @map("image_url")
  flowerPseudonym     String            @map("flower_pseudonym")
  
  // New moderation fields
  category            String            @default("story") // "confession", "story", "opinion"
  tags                String[]          @default([]) // JSON array of tags
  publicationStatus   String            @default("published") // "published", "under_review", "rejected"
  riskScore           Int               @default(0) @map("risk_score")
  moderationReason    String?           @map("moderation_reason")
  
  group               Group             @relation(fields: [groupId], references: [id])
  groupId             String            @map("group_id")
  reactions           Reaction[]
  comments            Comment[]
  reports             Report[]
  moderationActions   ModerationAction[]
  moderationQueue     ModerationQueue?
  
  isFlagged           Boolean           @default(false) @map("is_flagged")
  isRemoved           Boolean           @default(false) @map("is_removed")
  createdAt           DateTime          @default(now()) @map("created_at")

  // CRITICAL: No authorId. No User relation.

  @@map("posts")
}

model Reaction {
  id        String   @id @default(cuid())
  type      String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reactions")
}

model Comment {
  id              String   @id @default(cuid())
  content         String
  flowerPseudonym String   @map("flower_pseudonym")
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId          String   @map("post_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("comments")
}

// ─── Moderation Tables ───

model Report {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id")
  reason    String   // "harassment", "spam", "inappropriate", "other"
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  // No userId — reports are anonymous too.

  @@map("reports")
}

model ModerationAction {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id")
  action    String   // "flagged", "removed", "dismissed"
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("moderation_actions")
}

model ModerationQueue {
  id              String   @id @default(cuid())
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId          String   @unique @map("post_id")
  content         String
  category        String
  tags            String[] @default([])
  riskScore       Int      @map("risk_score")
  moderationReason String?  @map("moderation_reason")
  status          String   @default("pending") // "pending", "approved", "rejected"
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?  @map("reviewed_by") // Admin user ID (if manual review)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("moderation_queue")
}
